{
  "name": "nobet-cizelgesi-sistemi",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma", "sharp"]
  },
  "scripts": {
    "dev": "pnpm --filter @nobet/web dev",
    "build": "pnpm --filter @nobet/web build",
    "db:generate": "pnpm --filter @nobet/web db:generate",
    "db:push": "pnpm --filter @nobet/web db:push",
    "db:migrate": "pnpm --filter @nobet/web db:migrate",
    "db:seed": "pnpm --filter @nobet/web db:seed",
    "db:studio": "pnpm --filter @nobet/web db:studio"
  }
}
